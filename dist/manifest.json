{
  "name": "QuizWiz",
  "description": "Quiz Generator based on Question Bank",
  "manifest_version": 3,
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": "QuizWiz_128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
